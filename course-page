      for (let i = arr.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [arr[i], arr[j]] = [arr[j], arr[i]];
      }
      return arr;
    }

    function getProgress() {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
    }

    function setProgress(progress) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(progress));
    }

    function getFinalAttempts() {
      const val = localStorage.getItem(FINAL_ATTEMPTS_KEY);
      return val ? Number(val) : 2;
    }

    function setFinalAttempts(num) {
      localStorage.setItem(FINAL_ATTEMPTS_KEY, String(num));
    }

    function setFinalLocked() {
      localStorage.setItem(FINAL_LOCKED_KEY, 'true');
    }

    function isFinalLocked() {
      return localStorage.getItem(FINAL_LOCKED_KEY) === 'true';
    }

    function renderModuleQuiz(moduleId) {
      const target = document.getElementById('quiz-' + moduleId);
      const questions = moduleQuizzes[moduleId];
      target.innerHTML = questions.map((item, index) => {
        const options = item.options.map((opt, i) => `
          <label class="option">
            <input type="radio" name="${moduleId}-q${index}" value="${i}"> ${opt}
          </label>
        `).join('');

        return `
          <div class="question">
            <div class="question-title">${index + 1}. ${item.q}</div>
            ${options}
          </div>
        `;
      }).join('');
    }

    function gradeModule(moduleId) {
      const questions = moduleQuizzes[moduleId];
      const result = document.getElementById('result-' + moduleId);
      const status = document.getElementById('status-' + moduleId);
      let score = 0;

      for (let i = 0; i < questions.length; i++) {
        const selected = document.querySelector(`input[name="${moduleId}-q${i}"]:checked`);
        if (!selected) {
          result.className = 'result-box result-fail';
          result.style.display = 'block';
          result.textContent = 'Please answer all questions before submitting this module test.';
          return;
        }
        if (Number(selected.value) === questions[i].answer) {
          score++;
        }
      }

      const percent = Math.round((score / questions.length) * 100);
      const progress = getProgress();

      if (percent >= 80) {
        progress[moduleId] = true;
        setProgress(progress);
        result.className = 'result-box result-pass';
        result.style.display = 'block';
        result.textContent = `Passed: You scored ${score} out of ${questions.length} (${percent}%).`;
        status.textContent = 'Passed';
        status.className = 'module-status pass';
      } else {
        progress[moduleId] = false;
        setProgress(progress);
        result.className = 'result-box result-fail';
        result.style.display = 'block';
        result.textContent = `Not passed yet: You scored ${score} out of ${questions.length} (${percent}%). Review the module and try again.`;
        status.textContent = 'Not passed yet';
        status.className = 'module-status';
      }

      updateFinalLock();
    }

    function renderFinalQuestions() {
      finalQuestions = shuffle(finalQuestionBank).slice(0, 12);
      const form = document.getElementById('final-test');
      form.innerHTML = finalQuestions.map((item, index) => {
        const options = item.options.map((opt, i) => `
          <label class="option">
            <input type="radio" name="final-q${index}" value="${i}"> ${opt}
          </label>
        `).join('');
        return `
          <div class="question">
            <div class="question-title">${index + 1}. ${item.q}</div>
            ${options}
          </div>
        `;
      }).join('');
    }

    function updateFinalLock() {
      const progress = getProgress();
      const allPassed = ['m1','m2','m3','m4','m5','m6'].every((key) => progress[key] === true);
      const locked = isFinalLocked();
      const attempts = getFinalAttempts();

      const lockMsg = document.getElementById('final-lock-message');
      const liveArea = document.getElementById('final-live-area');
      const attemptInfo = document.getElementById('attempt-info');
      const submitBtn = document.getElementById('final-submit-btn');
      const finalResult = document.getElementById('final-result');

      if (locked || attempts <= 0) {
        lockMsg.style.display = 'block';
        lockMsg.innerHTML = '<h3>Final Test Locked</h3><p>You have used both final test attempts. No further attempts are available.</p>';
        liveArea.style.display = 'none';
        return;
      }

      if (allPassed) {
        lockMsg.style.display = 'none';
        liveArea.style.display = 'block';
        attemptInfo.textContent = `You have ${attempts} final test attempt${attempts === 1 ? '' : 's'} remaining.`;
        submitBtn.disabled = false;
        submitBtn.className = 'btn btn-primary';
        if (!finalQuestions.length) renderFinalQuestions();
        finalResult.style.display = 'none';
      } else {
        lockMsg.style.display = 'block';
        liveArea.style.display = 'none';
      }
    }

    function gradeFinalTest() {
      const attempts = getFinalAttempts();
      const result = document.getElementById('final-result');

      if (attempts <= 0 || isFinalLocked()) {
        updateFinalLock();
        return;
      }

      let score = 0;
      for (let i = 0; i < finalQuestions.length; i++) {
        const selected = document.querySelector(`input[name="final-q${i}"]:checked`);
        if (!selected) {
          result.className = 'result-box result-fail';
          result.style.display = 'block';
          result.textContent = 'Please answer all 12 final test questions before submitting.';
          return;
        }
        if (Number(selected.value) === finalQuestions[i].answer) {
          score++;
        }
      }

      const percent = Math.round((score / finalQuestions.length) * 100);
      const newAttempts = attempts - 1;
      setFinalAttempts(newAttempts);

      if (percent >= 80) {
        result.className = 'result-box result-pass';
        result.style.display = 'block';
        result.textContent = `Pass: You scored ${score} out of ${finalQuestions.length} (${percent}%). You have passed the final certification test.`;
      } else {
        result.className = 'result-box result-fail';
        result.style.display = 'block';
        if (newAttempts > 0) {
          result.textContent = `Not passed yet: You scored ${score} out of ${finalQuestions.length} (${percent}%). You have ${newAttempts} final attempt remaining.`;
          renderFinalQuestions();
        } else {
          setFinalLocked();
          result.textContent = `Not passed: You scored ${score} out of ${finalQuestions.length} (${percent}%). You have now used both final attempts.`;
        }
      }

      updateFinalLock();
    }

    function boot() {
      ['m1','m2','m3','m4','m5','m6'].forEach((id) => {
        renderModuleQuiz(id);
      });

      const progress = getProgress();
      ['m1','m2','m3','m4','m5','m6'].forEach((id) => {
        if (progress[id] === true) {
          const status = document.getElementById('status-' + id);
          status.textContent = 'Passed';
          status.className = 'module-status pass';
        }
      });

      updateFinalLock();
    }

    boot();
  </script>
</body>
</html>
